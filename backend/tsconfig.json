{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "module":  "commonjs",
                            "outDir":  "./dist",
                            "types": ["node"],
                            "esModuleInterop":  true,
                            "strict":  true,
                            "skipLibCheck":  true,
                            "allowSyntheticDefaultImports": true,
                            "resolveJsonModule":  true
                        },
    "include":  [
                    "src/**/*"
                ],
    "exclude":  [
                    "node_modules",
                    "dist"
                ]
}

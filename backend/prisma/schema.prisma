generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id             String          @id @default(uuid())
  email          String          @unique
  motDePasse     String?
  nom            String
  prenom         String
  telephone      String?
  role           Role
  actif          Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String?
  agence         AgenceVoyage?
  deviceTokens   DeviceToken[]
  famille        Famille?
  guide          Guide?
  notifications  Notification[]
  passwordTokens PasswordToken[]
  pelerin        Pelerin?
  refreshTokens  RefreshToken[]

  @@index([role])
}

model RefreshToken {
  id            String      @id @default(uuid())
  token         String      @unique
  utilisateurId String
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@index([utilisateurId])
}

model PasswordToken {
  id            String            @id @default(uuid())
  utilisateurId String
  tokenHash     String            @unique
  type          PasswordTokenType
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime          @default(now())
  utilisateur   Utilisateur       @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@index([utilisateurId])
}

model DeviceToken {
  id            String      @id @default(uuid())
  utilisateurId String
  token         String      @unique
  platform      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastSeenAt    DateTime    @default(now())
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@index([utilisateurId])
  @@index([platform])
}

model Notification {
  id            String      @id @default(uuid())
  utilisateurId String
  title         String
  body          String
  type          String?
  tab           String?
  groupeId      String?
  eventId       String?
  etape         String?
  isRead        Boolean     @default(false)
  readAt        DateTime?
  createdAt     DateTime    @default(now())
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@index([utilisateurId, createdAt(sort: Desc)])
  @@index([utilisateurId, isRead])
}

model RagChunk {
  id         String                @id @default(uuid())
  text       String
  source     String
  section    String?
  audience   String[]
  language   String                @default("fr")
  tags       String[]
  documentId String?
  createdAt  DateTime              @default(now())
  embedding  Unsupported("vector")

  @@index([language])
}

model AgenceVoyage {
  id              String       @id @default(uuid())
  utilisateurId   String       @unique
  nomAgence       String
  adresse         String?
  siteWeb         String?
  logo            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  status          StatutAgence @default(PENDING)
  approvedById    String?
  rejectedById    String?
  utilisateur     Utilisateur  @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  familles        Famille[]
  groupes         Groupe[]
  guides          Guide[]
  pelerins        Pelerin[]

  @@index([status])
}

model Guide {
  id                 String              @id @default(uuid())
  utilisateurId      String              @unique
  agenceId           String
  specialite         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  disponibilite      DisponibiliteGuide  @default(DISPONIBLE)
  disponibiliteMajAt DateTime?
  alertesResolues    AlerteSOS[]         @relation("GuideResolutionSOS")
  appelsPresence     AppelPresence[]
  evenementsValides  EvenementPlanning[]
  groupes            GroupeGuide[]
  agence             AgenceVoyage        @relation(fields: [agenceId], references: [id])
  utilisateur        Utilisateur         @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@index([agenceId])
}

model Groupe {
  id             String              @id @default(uuid())
  nom            String
  description    String?
  annee          Int
  typeVoyage     TypeVoyage          @default(HAJJ)
  agenceId       String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  dateDepart     DateTime?
  dateRetour     DateTime?
  nbMax          Int?
  status         StatutGroupe        @default(PLANIFIE)
  hajjStartDate  DateTime?
  alertesSOS     AlerteSOS[]
  appelsPresence AppelPresence[]
  agence         AgenceVoyage        @relation(fields: [agenceId], references: [id])
  guides         GroupeGuide[]
  membres        GroupePelerin[]
  plannings      PlanningQuotidien[]

  @@index([agenceId])
  @@index([annee])
  @@index([status])
}

model GroupeGuide {
  id        String    @id @default(uuid())
  groupeId  String
  guideId   String
  dateDebut DateTime  @default(now())
  dateFin   DateTime?
  actif     Boolean   @default(true)
  groupe    Groupe    @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  guide     Guide     @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([groupeId, actif])
  @@index([guideId, actif])
}

model GroupePelerin {
  id        String    @id @default(uuid())
  groupeId  String
  pelerinId String
  dateDebut DateTime  @default(now())
  dateFin   DateTime?
  actif     Boolean   @default(true)
  groupe    Groupe    @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  pelerin   Pelerin   @relation(fields: [pelerinId], references: [id], onDelete: Cascade)

  @@index([groupeId, actif])
  @@index([pelerinId, actif])
}

model Pelerin {
  id              String                 @id @default(uuid())
  utilisateurId   String                 @unique
  codeUnique      String                 @unique
  agenceId        String
  dateNaissance   DateTime?
  nationalite     String?
  numeroPasseport String?
  photoUrl        String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  statut          StatutPelerin          @default(PRESENT)
  alertesSOS      AlerteSOS[]
  confirmations   ConfirmationPresence[]
  familles        FamillePelerin[]
  groupes         GroupePelerin[]
  agence          AgenceVoyage           @relation(fields: [agenceId], references: [id])
  utilisateur     Utilisateur            @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  positions       Position[]

  @@index([agenceId])
  @@index([statut])
}

model Famille {
  id            String           @id @default(uuid())
  utilisateurId String           @unique
  lienParente   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  agenceId      String
  agence        AgenceVoyage     @relation(fields: [agenceId], references: [id])
  utilisateur   Utilisateur      @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  associations  FamillePelerin[]

  @@index([agenceId])
}

model FamillePelerin {
  id        String   @id @default(uuid())
  familleId String
  pelerinId String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  famille   Famille  @relation(fields: [familleId], references: [id], onDelete: Cascade)
  pelerin   Pelerin  @relation(fields: [pelerinId], references: [id], onDelete: Cascade)

  @@unique([familleId, pelerinId])
  @@index([familleId])
  @@index([pelerinId])
}

model PlanningQuotidien {
  id         String              @id @default(uuid())
  groupeId   String
  date       DateTime
  titre      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  evenements EvenementPlanning[]
  groupe     Groupe              @relation(fields: [groupeId], references: [id], onDelete: Cascade)

  @@unique([groupeId, date])
  @@index([groupeId, date])
}

model EvenementPlanning {
  id                  String            @id @default(uuid())
  planningQuotidienId String
  type                TypeEvenement
  titre               String
  description         String?
  lieu                String?
  createdAt           DateTime          @default(now())
  heureDebutPrevue    DateTime?
  updatedAt           DateTime          @updatedAt
  estValide           Boolean           @default(false)
  etape               EtapeVoyage?
  valideParGuideId    String?
  valideeAt           DateTime?
  status              StatutEvenement   @default(PLANIFIE)
  planningQuotidien   PlanningQuotidien @relation(fields: [planningQuotidienId], references: [id], onDelete: Cascade)
  validePar           Guide?            @relation(fields: [valideParGuideId], references: [id])

  @@index([planningQuotidienId])
  @@index([valideParGuideId])
  @@index([etape])
}

model AppelPresence {
  id            String                 @id @default(uuid())
  groupeId      String
  guideId       String
  date          DateTime               @default(now())
  statut        StatutAppel            @default(EN_COURS)
  createdAt     DateTime               @default(now())
  clotureAt     DateTime?
  groupe        Groupe                 @relation(fields: [groupeId], references: [id])
  guide         Guide                  @relation(fields: [guideId], references: [id])
  confirmations ConfirmationPresence[]

  @@index([groupeId])
  @@index([guideId])
  @@index([date])
}

model ConfirmationPresence {
  id              String            @id @default(uuid())
  appelPresenceId String
  pelerinId       String
  statut          StatutPresence    @default(EN_ATTENTE)
  confirmeAt      DateTime?
  confirmeMode    ModeConfirmation?
  note            String?
  createdAt       DateTime          @default(now())
  appelPresence   AppelPresence     @relation(fields: [appelPresenceId], references: [id], onDelete: Cascade)
  pelerin         Pelerin           @relation(fields: [pelerinId], references: [id])

  @@unique([appelPresenceId, pelerinId])
  @@index([appelPresenceId])
  @@index([pelerinId])
}

model Position {
  id        String   @id @default(uuid())
  pelerinId String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  pelerin   Pelerin  @relation(fields: [pelerinId], references: [id], onDelete: Cascade)

  @@index([pelerinId, createdAt(sort: Desc)])
}

model AlerteSOS {
  id                String       @id @default(uuid())
  pelerinId         String
  latitude          Float
  longitude         Float
  statut            StatutAlerte @default(EN_COURS)
  message           String?
  createdAt         DateTime     @default(now())
  resolueAt         DateTime?
  resolueParGuideId String?
  groupeId          String
  type              TypeIncident @default(AUTRE)
  description       String?
  groupe            Groupe       @relation(fields: [groupeId], references: [id])
  pelerin           Pelerin      @relation(fields: [pelerinId], references: [id], onDelete: Cascade)
  resolueParGuide   Guide?       @relation("GuideResolutionSOS", fields: [resolueParGuideId], references: [id])

  @@index([pelerinId])
  @@index([groupeId])
  @@index([statut])
  @@index([resolueParGuideId])
}

enum Role {
  PELERIN
  GUIDE
  AGENCE
  FAMILLE
  SUPER_ADMIN
}

enum TypeVoyage {
  HAJJ
  UMRAH
}

enum StatutGroupe {
  PLANIFIE
  EN_COURS
  TERMINE
  ANNULE
}

enum StatutEvenement {
  PLANIFIE
  EN_COURS
  TERMINE
  ANNULE
}

enum DisponibiliteGuide {
  DISPONIBLE
  INDISPONIBLE
}

enum EtapeVoyage {
  IHRAM
  TAWAF_AL_QUDUM
  SAI
  ARAFAT
  MUZDALIFAH
  MINA
  RAMI_JAMARAT
  TAWAF_AL_IFADA
  TAWAF_AL_WADA
  TAHALLUL
  TAWAF_UMRAH
}

enum TypeEvenement {
  PRIERE
  TRANSPORT
  REPAS
  RITE
  REPOS
  AUTRE
  VISITE
}

enum StatutAgence {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PasswordTokenType {
  SET_PASSWORD
  RESET_PASSWORD
}

enum StatutPelerin {
  PRESENT
  EN_DEPLACEMENT
  BESOIN_AIDE
  SOS
}

enum StatutAppel {
  EN_COURS
  CLOTURE
}

enum StatutPresence {
  EN_ATTENTE
  PRESENT
  ABSENT
  EXCUSE
}

enum ModeConfirmation {
  AUTOMATIQUE
  MANUEL
  QR
}

enum StatutAlerte {
  EN_COURS
  RESOLUE
  ANNULEE
}

enum TypeIncident {
  SOS
  MALADIE
  PERTE
  LOGISTIQUE
  AUTRE
}

generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id            String         @id @default(uuid())
  email         String         @unique
  motDePasse    String
  nom           String
  prenom        String
  telephone     String?
  role          Role
  actif         Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdById   String?
  agence        AgenceVoyage?
  guide         Guide?
  pelerin       Pelerin?
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id            String      @id @default(uuid())
  token         String      @unique
  utilisateurId String
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model AgenceVoyage {
  id            String      @id @default(uuid())
  utilisateurId String      @unique
  nomAgence     String
  adresse       String?
  siteWeb       String?
  logo          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  groupes       Groupe[]
  guides        Guide[]
  pelerins      Pelerin[]
}

model Guide {
  id            String       @id @default(uuid())
  utilisateurId String       @unique
  agenceId      String
  specialite    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  groupes       Groupe[]
  agence        AgenceVoyage @relation(fields: [agenceId], references: [id])
  utilisateur   Utilisateur  @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model Groupe {
  id          String              @id @default(uuid())
  nom         String
  description String?
  annee       Int
  typeVoyage  TypeVoyage          @default(HAJJ)
  agenceId    String
  guideId     String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  agence      AgenceVoyage        @relation(fields: [agenceId], references: [id])
  guide       Guide?              @relation(fields: [guideId], references: [id])
  pelerins    Pelerin[]
  plannings   PlanningQuotidien[]
}

model Pelerin {
  id              String         @id @default(uuid())
  sutilisateurId   String         @unique
  codeUnique      String?        @unique
  agenceId        String
  groupeId        String?
  dateNaissance   DateTime?
  nationalite     String?
  numeroPasseport String?
  photoUrl        String?
  etapeActuelle   EtapeHajj?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  etapesValidees  EtapeValidee[]
  agence          AgenceVoyage   @relation(fields: [agenceId], references: [id])
  groupe          Groupe?        @relation(fields: [groupeId], references: [id])
  utilisateur     Utilisateur    @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model EtapeValidee {
  id        String    @id @default(uuid())
  pelerinId String
  etape     EtapeHajj
  valideeAt DateTime  @default(now())
  note      String?
  pelerin   Pelerin   @relation(fields: [pelerinId], references: [id], onDelete: Cascade)

  @@unique([pelerinId, etape])
}

model PlanningQuotidien {
  id         String              @id @default(uuid())
  groupeId   String
  date       DateTime
  titre      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  evenements EvenementPlanning[]
  groupe     Groupe              @relation(fields: [groupeId], references: [id], onDelete: Cascade)

  @@unique([groupeId, date])
}

model EvenementPlanning {
  id                  String            @id @default(uuid())
  planningQuotidienId String
  type                TypeEvenement
  titre               String
  description         String?
  heureDebut          DateTime
  heureFin            DateTime?
  lieu                String?
  createdAt           DateTime          @default(now())
  planningQuotidien   PlanningQuotidien @relation(fields: [planningQuotidienId], references: [id], onDelete: Cascade)
}

enum Role {
  PELERIN
  GUIDE
  AGENCE
  FAMILLE
  SUPER_ADMIN
}

enum TypeVoyage {
  HAJJ
  UMRAH
}

enum EtapeHajj {
  IHRAM
  ARRIVEE_MECQUE
  TAWAF
  SAI
  ARAFAT
  MUZDALIFA
  MINA
  RAMI_JAMARAT
  TAWAF_IFADA
}

enum TypeEvenement {
  PRIERE
  TRANSPORT
  REPAS
  RITE
  REPOS
  AUTRE
}

